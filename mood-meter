/* ---------------- Presence ---------------- */
function isOnline(uid){
  const t = presenceMap[uid];
  return !!t && (Date.now() - t) < ONLINE_WINDOW_MS;
}
function heartbeat(){
  if(!currentUser) return;
  setDoc(doc(db, "presence", currentUser.uid), {
    lastActive: serverTimestamp(), name: currentUser.displayName || "Friend"
  }, { merge: true }).catch(() => {});
}
function startPresence(){
  heartbeat();
  if(heartbeatTimer) clearInterval(heartbeatTimer);
  heartbeatTimer = setInterval(heartbeat, 25000);
  document.addEventListener("visibilitychange", () => { if(document.visibilityState === "visible") heartbeat(); });
  const presenceQuery = query(presenceCol, orderBy("lastActive","desc"), limit(300));
  onSnapshot(presenceQuery, (snap) => {
    presenceMap = {};
    snap.docs.forEach(d => { presenceMap[d.id] = d.data().lastActive?.toMillis?.() || 0; });
    if(!els.chatFullPage.classList.contains("hidden")) updateChatHeaderPresence();
  }, (err) => console.error(err));
}
