const views = ["home","feed","messages","analytics","profile"];
function switchView(view){
  // 🛠️ AUTOMATIC CHAT OVERLAY DISMISSAL ON TAB SWITCH
  // Every nav button (desktop + mobile) routes through here, so this is
  // the single choke point that guarantees an open direct-message thread
  // is torn down the instant any tab is tapped — no stuck overlay, no
  // leftover Firestore message listener running behind the new view.
  currentConvId = null;
  currentConvTarget = null;
  closeChatFullPage();

  views.forEach(v => $("view-"+v).classList.toggle("hidden", v !== view));
  document.querySelectorAll(".tab-btn").forEach(b => { b.classList.toggle("active", b.dataset.view === view); b.classList.toggle("text-white/70", b.dataset.view !== view); });
  document.querySelectorAll(".bottom-tab").forEach(b => b.classList.toggle("active", b.dataset.view === view));
  $("view-"+view).classList.add("fade-in");
  if(view === "feed"){ if(feedSubTab === "recent") renderFeed(); else renderTrending(); }
  if(view === "profile"){ renderProfile(); refreshMyFollowCounts(currentUser.uid); }
  if(view === "analytics") { initAnalyticsView(); }
  if(view === "messages") renderMessagesView();
}
