    els.globalMonthPicker.classList.toggle("hidden", mode !== "monthly");
    els.globalDatePickerLabel.textContent = mode === "daily" ? "Viewing date" : "Viewing month";
    els.globalDateTodayBtn.textContent = mode === "daily" ? "Today" : "This Month";
    if(mode === "daily") loadGlobalDayFromCache();
    else loadGlobalMonthFromCache(globalSelectedMonth);
  });
});

function renderWeeklyChart(docsArr){
  const days = [];
  for(let i=6;i>=0;i--){ const d = new Date(); d.setDate(d.getDate()-i); days.push(localDateStr(d)); }
  const dayCounts = days.map(day => docsArr.filter(d => d.day === day).length);
  const maxVal = Math.max(...dayCounts, 1);
  els.weeklyChart.innerHTML = ""; els.weeklyLabels.innerHTML = "";
  const dayNames = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
  days.forEach((day, i) => {
    const h = Math.round((dayCounts[i] / maxVal) * 100);
    const col = document.createElement("div");
    col.className = "flex-1 flex flex-col items-center justify-end h-full";
    col.innerHTML = `<div class="text-[10px] text-white/40 mb-1">${dayCounts[i]}</div>
      <div class="bar-fill w-full rounded-t-lg" style="height:${Math.max(h,4)}%; background:linear-gradient(180deg, rgba(255,205,90,0.9), rgba(120,170,255,0.6));"></div>`;
    els.weeklyChart.appendChild(col);
    // day is a YYYY-MM-DD local-timezone key; parse with explicit parts to
    // avoid any UTC re-interpretation when deriving the weekday label.
    const [yy, mm, dd] = day.split("-").map(Number);
    const lbl = document.createElement("span"); lbl.textContent = dayNames[new Date(yy, mm-1, dd).getDay()];
    els.weeklyLabels.appendChild(lbl);
  });
}

/* ---------- BLOCK B: My Historical Personal Sanctuary ---------- */

function populateMonthYearSelectors(){
  els.myMonthSelect.innerHTML = MONTH_NAMES.map((m,i) => `<option value="${i}" ${i===myMonthSelVal?"selected":""}>${m}</option>`).join("");
  const nowYear = new Date().getFullYear();
  const entryYears = myDocs.map(d => d.day ? parseInt(d.day.slice(0,4),10) : nowYear).filter(y => !isNaN(y));
  const earliest = entryYears.length ? Math.min(...entryYears, nowYear) : nowYear - 1;
  const years = [];
  for(let y = nowYear; y >= earliest; y--) years.push(y);
  els.myMonthYearSelect.innerHTML = years.map(y => `<option value="${y}" ${y===myMonthYearSelVal?"selected":""}>${y}</option>`).join("");
  els.myYearSelect.innerHTML = years.map(y => `<option value="${y}" ${y===myYearSelVal?"selected":""}>${y}</option>`).join("");
}

