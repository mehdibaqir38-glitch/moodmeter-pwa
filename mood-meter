function paintMessages(msgs){
  // 🔒 FEATURE 1 CLIENT-SIDE GUARD: filter out any message whose expireAt
  // has already passed. This runs on every snapshot, in addition to the
  // server-side Firestore TTL sweep, so an expired message can never
  // flash on screen even in the window before TTL physically deletes it.
  msgs = msgs.filter(m => !isMessageExpired(m));

  if(msgs.length === 0){
    setHtmlIfChanged(els.chatBody, `<div class="text-xs text-white/30 text-center py-8">Say hi 👋 — sending a message starts a private request with this person.</div>`);
    return;
  }
  let lastMineIndex = -1;
  msgs.forEach((m, i) => { if(m.senderId === currentUser.uid && !m.deleted) lastMineIndex = i; });
  const lastMineSeen = lastMineIndex >= 0 && msgs[lastMineIndex].status === "read";

  const html = msgs.map((m, i) => {
    const mine = currentUser && m.senderId === currentUser.uid;
    if(m.deleted){
      return `<div class="flex flex-col ${mine ? "items-end" : "items-start"}">
        <div class="bg-white/5 text-white/30 italic rounded-2xl px-3 py-2 text-sm max-w-[75%]">Message deleted</div>
        <span class="text-[10px] text-white/40 mt-1 px-1">${formatMsgTime(m.timestamp)}</span>
      </div>`;
    }
    const actionsHtml = mine ? `
      <div class="flex gap-2 mt-1 justify-end text-[10px] text-white/30">
        <button class="editMsgBtn hover:text-white/60" data-id="${m.id}">✏️ Edit</button>
        <button class="deleteMsgBtn hover:text-red-300" data-id="${m.id}">🗑️ Delete</button>
      </div>` : "";
    const seenHtml = (mine && i === lastMineIndex && lastMineSeen) ? `
      <div class="flex items-center gap-1 mt-1 justify-end">
        <div class="seen-avatar" title="Seen by ${escapeHtml(chatHeaderTargetName)}">${chatHeaderTargetName.charAt(0).toUpperCase()}</div>
        <span class="text-[9px] text-white/30">Seen</span>
      </div>` : "";
    return `<div class="flex flex-col ${mine ? "items-end" : "items-start"}">
      <div class="msg-bubble ${mine ? "bg-white text-black" : "bg-white/10 text-white"} rounded-2xl px-4 py-2.5 text-sm break-words">${escapeHtml(m.text)}${m.edited ? ` <span class="text-[10px] opacity-50">(edited)</span>` : ""}</div>
      <span class="text-[10px] text-white/40 mt-1 px-1">${formatMsgTime(m.timestamp)}</span>
      ${actionsHtml}
      ${seenHtml}
    </div>`;
  }).join("");
  const changed = setHtmlIfChanged(els.chatBody, html);
  if(changed) els.chatBody.scrollTop = els.chatBody.scrollHeight;
}

els.chatBody.addEventListener("click", async (e) => {
  const editBtn = e.target.closest(".editMsgBtn");
  if(editBtn){
    const newText = prompt("Edit your message:");
    if(newText === null || !newText.trim()) return;
    try{ await updateDoc(doc(db, "conversations", currentConvId, "messages", editBtn.dataset.id), { text: newText.trim().slice(0,500), edited: true }); }
    catch(err){ console.error(err); showToast("Couldn't edit message.", "error"); }
    return;
  }
  const deleteBtn = e.target.closest(".deleteMsgBtn");
  if(deleteBtn){
    if(!confirm("Delete this message?")) return;
    try{ await updateDoc(doc(db, "conversations", currentConvId, "messages", deleteBtn.dataset.id), { deleted: true, text: "" }); }
    catch(err){ console.error(err); showToast("Couldn't delete message.", "error"); }
    return;
  }
});

els.chatForm.addEventListener("submit", async (e) => {
  e.preventDefault();
  if(!currentUser || !currentConvId) return;
  if(isBlocked(currentConvTarget)){ showToast("Unblock this user to send messages.", "error"); return; }
  const text = els.chatInput.value.trim();
  if(!text) return;
  try{
    const existing = conversations.find(c => c.id === currentConvId);
    const unreadPatch = { [`unreadFor.${currentConvTarget}`]: true, [`unreadFor.${currentUser.uid}`]: false };
    if(!existing){
      await setDoc(doc(db, "conversations", currentConvId), {
        participants: [currentUser.uid, currentConvTarget], status: "pending", initiator: currentUser.uid,
        updatedAt: serverTimestamp(), lastMessage: text.slice(0,80), lastMessageSenderId: currentUser.uid,
        unreadFor: { [currentConvTarget]: true, [currentUser.uid]: false }
      }, { merge: true });
    } else if(existing.status === "pending" && existing.initiator !== currentUser.uid){
      await updateDoc(doc(db, "conversations", currentConvId), { status: "accepted", updatedAt: serverTimestamp(), lastMessage: text.slice(0,80), lastMessageSenderId: currentUser.uid, ...unreadPatch });
      els.chatBanner.classList.add("hidden");
    } else {
      await updateDoc(doc(db, "conversations", currentConvId), { updatedAt: serverTimestamp(), lastMessage: text.slice(0,80), lastMessageSenderId: currentUser.uid, ...unreadPatch });
    }
    // ⏱️ FEATURE 1: every message independently carries its own createdAt
    // (server timestamp) and expireAt (createdAt + exactly 7 days). Message
    // A sent today and Message B sent tomorrow each get their own expireAt,
    // computed at write time — never derived from, or tied to, any other
    // message or the conversation document itself.
    await addDoc(collection(db, "conversations", currentConvId, "messages"), {
      senderId: currentUser.uid, text: text.slice(0,500),
      timestamp: serverTimestamp(),      // kept for existing ordering/display logic
      createdAt: serverTimestamp(),      // FEATURE 1: authoritative creation time
      expireAt: computeExpireAtTimestamp(), // FEATURE 1: createdAt + 7 days, watched by Firestore TTL
      status: "unread", edited: false, deleted: false
    });
    els.chatInput.value = "";
  } catch(err){ console.error(err); showToast("Couldn't send message.", "error"); }
});

