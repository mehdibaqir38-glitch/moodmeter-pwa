async function markConversationRead(convId, uid){
  try{ await updateDoc(doc(db, "conversations", convId), { [`unreadFor.${uid}`]: false }); }
  catch(err){ /* conversation may not exist yet — safe to ignore */ }
}
async function markMessagesRead(convId, uid, msgs){
  const unreadIncoming = msgs.filter(m => m.senderId !== uid && m.status === "unread");
  if(unreadIncoming.length === 0) return;
  try{ await Promise.all(unreadIncoming.map(m => updateDoc(doc(db, "conversations", convId, "messages", m.id), { status: "read" }))); }
  catch(err){ console.error(err); }
}

// ============================================================================
// ⏱️ FEATURE 1: 7-DAY AUTOMATIC CHAT MESSAGE EXPIRATION — helper functions
// ============================================================================
// Every message document independently carries:
//   • createdAt -> Firebase Server Timestamp (authoritative send time)
//   • expireAt  -> a real Firestore Timestamp exactly 7 days after createdAt,
//                  computed from the client clock (Firestore TTL requires an
//                  actual Timestamp value — it cannot use the serverTimestamp()
//                  sentinel — so we compute it as "now + 7 days" at write time).
// This `expireAt` field is what the Firestore TTL policy (configured once in
// the Firebase Console / gcloud CLI — see the note below the code) watches to
// permanently delete the document server-side, even if nobody ever reopens
// the conversation. Until that background sweep runs, isMessageExpired()
// below hides any already-expired message from the UI immediately.
function computeExpireAtTimestamp(){
  return Timestamp.fromMillis(Date.now() + MESSAGE_TTL_MS);
}
function isMessageExpired(m){
  // Prefer the authoritative server-computed expireAt field. Messages written
  // before this feature shipped (no expireAt) are treated as not-yet-expired
  // so existing conversations keep working exactly as before.
  if(m.expireAt && typeof m.expireAt.toMillis === "function"){
    return m.expireAt.toMillis() <= Date.now();
  }
  return false;
}

