// ============================================================================
// 📊 FEATURE 2: MONTHLY GLOBAL MOOD SUMMARY
// ============================================================================
// Adds a Daily / Monthly mode selector above the existing Global date picker.
// Daily mode is 100% unchanged from before. Monthly mode reuses the exact
// same donut + bars UI, but its data source becomes every public mood log
// whose `day` field (already computed with the same client-local timezone
// logic used everywhere else in the app — see localDateStr() above) falls
// within the selected calendar month, from the 1st at 00:00:00 through the
// last day at 23:59:59 local time.

function monthRangeStrs(monthStr){
  // monthStr is "YYYY-MM". Returns the first and last "YYYY-MM-DD" day keys
  // for that month — using simple string arithmetic so it lines up exactly
  // with the local-timezone `day` keys already stored on every mood doc.
  const [y, m] = monthStr.split("-").map(Number);
  const first = `${monthStr}-01`;
  const lastDate = new Date(y, m, 0).getDate(); // day 0 of next month = last day of this month
  const last = `${monthStr}-${String(lastDate).padStart(2,"0")}`;
  return { first, last };
}

function loadGlobalDayFromCache(){
  const cached = communityDocs.filter(d => d.day === globalSelectedDate && d.isPublic !== false);
  globalDayDocs = cached;
  paintGlobalPeriod();
}

async function fetchGlobalDay(dateStr){
  els.globalDateLoading.classList.remove("hidden");
  try{
    const q = query(moodsCol, where("day", "==", dateStr), limit(500));
    const snap = await getDocs(q);
    globalDayDocs = snap.docs.map(d => ({ id: d.id, ...d.data() })).filter(d => d.isPublic !== false);
  } catch(err){
    console.error(err);
    showToast("Couldn't load that day's data — check Firestore rules.", "error");
    globalDayDocs = communityDocs.filter(d => d.day === dateStr && d.isPublic !== false);
  }
  els.globalDateLoading.classList.add("hidden");
  paintGlobalPeriod();
}

// FEATURE 2: fetch every public mood log for an entire calendar month —
// first day 00:00:00 through last day 23:59:59, using the same local `day`
// key logic as Daily Statistics. A local-cache fallback (mirroring the Daily
// path above) keeps things working even if the range query hits a rules or
// index issue while Firestore auto-builds the needed index.
async function fetchGlobalMonth(monthStr){
  els.globalDateLoading.classList.remove("hidden");
  const { first, last } = monthRangeStrs(monthStr);
  try{
    const q = query(moodsCol, where("day", ">=", first), where("day", "<=", last), limit(2000));
    const snap = await getDocs(q);
    globalDayDocs = snap.docs.map(d => ({ id: d.id, ...d.data() })).filter(d => d.isPublic !== false);
  } catch(err){
    console.error(err);
    showToast("Couldn't load that month's data — check Firestore rules/indexes.", "error");
    globalDayDocs = communityDocs.filter(d => d.day && d.day >= first && d.day <= last && d.isPublic !== false);
  }
  els.globalDateLoading.classList.add("hidden");
  paintGlobalPeriod();
}

function loadGlobalMonthFromCache(monthStr){
  const { first, last } = monthRangeStrs(monthStr);
  globalDayDocs = communityDocs.filter(d => d.day && d.day >= first && d.day <= last && d.isPublic !== false);
  paintGlobalPeriod();
}

// Unified paint function for BOTH Daily and Monthly modes — reuses the exact
// same donut chart and breakdown bars UI already built for Daily Statistics;
// only the heading text and the underlying data source (globalDayDocs) change.
function paintGlobalPeriod(){
  const total = globalDayDocs.length;
  const counts = buildMoodCounts();
  globalDayDocs.forEach(d => { if(counts[d.mood] !== undefined) counts[d.mood]++; });

  if(globalMode === "daily"){
    const dateObj = new Date(globalSelectedDate + "T00:00:00");
    const isToday = globalSelectedDate === todayStr();
    const label = dateObj.toLocaleDateString(undefined, { weekday: "long", month: "long", day: "numeric", year: "numeric" });
    els.globalDayHeading.textContent = `${isToday ? "Today's" : label + "'s"} Global Vibe Share`;
    els.globalDayEmpty.textContent = "No public entries logged on this date yet.";
  } else {
    const [y, m] = globalSelectedMonth.split("-").map(Number);
    const label = `${MONTH_NAMES[m-1]} ${y}`;
    els.globalDayHeading.textContent = `${label} Global Vibe Share`;
    els.globalDayEmpty.textContent = "No public entries logged in this month yet.";
  }

  renderDonutSVG(els.globalDonutWrap, counts, total);
  els.globalDayEmpty.classList.toggle("hidden", total > 0);
  els.globalDayBars.classList.toggle("hidden", total === 0);
  if(total > 0) paintMoodBreakdownBars(els.globalDayBars, counts, total, "");
}

function initGlobalDatePicker(){
  els.globalDatePicker.value = globalSelectedDate;
  els.globalDatePicker.max = todayStr();
  els.globalMonthPicker.value = globalSelectedMonth;
  els.globalMonthPicker.max = todayStr().slice(0,7);
  if(globalMode === "daily") loadGlobalDayFromCache();
  else loadGlobalMonthFromCache(globalSelectedMonth);
}
els.globalDatePicker.addEventListener("change", (e) => {
  const val = e.target.value;
  if(!val) return;
  globalSelectedDate = val;
  if(val === todayStr()){ loadGlobalDayFromCache(); }
  else { fetchGlobalDay(val); }
});
els.globalMonthPicker.addEventListener("change", (e) => {
  const val = e.target.value;
  if(!val) return;
  globalSelectedMonth = val;
  if(val === todayStr().slice(0,7)){ loadGlobalMonthFromCache(val); }
  else { fetchGlobalMonth(val); }
});
els.globalDateTodayBtn.addEventListener("click", () => {
  if(globalMode === "daily"){
    globalSelectedDate = todayStr();
    els.globalDatePicker.value = globalSelectedDate;
