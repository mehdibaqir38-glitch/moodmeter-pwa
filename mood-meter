// FEATURE 2: Daily / Monthly mode toggle. Switching modes never reloads the
// page — it instantly swaps which picker is visible and repaints the exact
// same donut + bars UI from the newly selected data source.
document.querySelectorAll("#globalModeTabs .mode-btn").forEach(btn => {
