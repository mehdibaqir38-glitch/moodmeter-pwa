function timeAgo(ts){
  if(!ts || !ts.toDate) return "just now";
  const diffMs = Date.now() - ts.toDate().getTime();
  const mins = Math.floor(diffMs/60000);
  if(mins < 1) return "just now";
  if(mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins/60);
  if(hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs/24)}d ago`;
}
function reactionCount(d, key){ return Object.keys(d.reactionsMeta?.[key] || {}).length; }
function userReacted(d, key){ return !!(currentUser && d.reactionsMeta?.[key]?.[currentUser.uid]); }
function findDocById(id){
  return myDocs.find(x => x.id === id) || feedDocs.find(x => x.id === id) || trendingDocs.find(x => x.id === id) || communityDocs.find(x => x.id === id);
}

function nameHtml(d){
  const name = d.isAnonymous ? "Anonymous" : (d.displayName || "Friend");
  if(d.isAnonymous || !currentUser) return `<span class="text-sm font-medium">${escapeHtml(name)}</span>`;
  return `<button class="profileLink text-sm font-medium name-link" data-uid="${d.userId}" data-name="${escapeHtml(name)}">${escapeHtml(name)}</button>`;
}

function renderFeed(){
  let source = feedScope === "mine" ? myDocs : feedDocs.filter(d => d.isPublic !== false);
  let docsArr = source;
  if(feedFilterVal !== "all") docsArr = docsArr.filter(d => d.mood === feedFilterVal);
  if(feedSortVal === "loved"){
    docsArr = [...docsArr].sort((a,b) => (reactionCount(b,"heart")+reactionCount(b,"hug")+reactionCount(b,"strength")) - (reactionCount(a,"heart")+reactionCount(a,"hug")+reactionCount(a,"strength")));
  }

  if(docsArr.length === 0){
    setHtmlIfChanged(els.feedList, "");
    els.feedEmpty.classList.remove("hidden");
    els.feedEmpty.textContent = feedScope === "mine" ? "You haven't posted anything yet — log a mood to see it here." : "No posts yet for this filter in the last 24 hours. Be the first to share 🌱";
