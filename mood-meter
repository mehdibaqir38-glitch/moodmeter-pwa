function subscribeConversations(uid){
  const q = query(convsCol, where("participants", "array-contains", uid), orderBy("updatedAt", "desc"), limit(100));
  onSnapshot(q, (snap) => {
    conversations = snap.docs.map(d => ({ id: d.id, ...d.data() })).filter(c => c.status !== "declined");
    updateMessageBadges();
    if(!$("view-messages").classList.contains("hidden")) renderMessagesView();
    if(!els.chatFullPage.classList.contains("hidden")) updateChatBanner();
  }, (err) => console.error(err));
}
function updateMessageBadges(){
  if(!currentUser) return;
  // Blocked conversations remain included in badge counts (no filter)
  const allConvs = conversations;
  const requestsCount = allConvs.filter(c => c.status === "pending" && c.initiator !== currentUser.uid).length;
  const unreadActiveCount = allConvs.filter(c => c.status === "accepted" && c.unreadFor && c.unreadFor[currentUser.uid]).length;
  const totalBadge = requestsCount + unreadActiveCount;
  els.reqCountPill.textContent = requestsCount;
  els.reqCountPill.classList.toggle("hidden", requestsCount === 0);
  [els.msgNavBadgeDesktop, els.msgNavBadgeMobile].forEach(b => {
    b.textContent = totalBadge;
    b.classList.toggle("hidden", totalBadge === 0);
  });
}

