<!-- ================= LANDING PAGE INTERACTIVITY (SEO, Privacy, Terms toggles) ================= -->
<script>
  (function() {
    function setupToggle(triggerId, contentId, labelReadMore, labelReadLess) {
      const btn = document.getElementById(triggerId);
      const content = document.getElementById(contentId);
      if (!btn || !content) return;
      let expanded = false;
      btn.addEventListener('click', () => {
        expanded = !expanded;
        if (expanded) {
          content.classList.add('open');
          btn.textContent = labelReadLess + ' ↑';
        } else {
          content.classList.remove('open');
          btn.textContent = labelReadMore + ' ↓';
        }
      });
    }

    // SEO article
    setupToggle('seo-read-more-btn', 'seo-full-content', 'Read More', 'Read Less');
    // Privacy policy
    setupToggle('privacy-read-more-btn', 'privacy-full', 'Read More', 'Read Less');
    // Terms & conditions
    setupToggle('terms-read-more-btn', 'terms-full', 'Read More', 'Read Less');

    // Smooth scroll for footer links (same page anchors)
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  })();
</script>


