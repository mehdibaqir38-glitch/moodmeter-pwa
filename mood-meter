async function handleCommentSubmit(e){
  const form = e.target.closest(".commentForm");
  if(!form) return;
  e.preventDefault();
  if(!currentUser) return;
  const input = form.querySelector(".commentInput");
  const text = input.value.trim();
  if(!text) return;
  const postId = form.dataset.id;
  const parentId = input.dataset.parentId || null;
  try{
    const commentsCol = collection(db, "moods", postId, "comments");
    await addDoc(commentsCol, {
      text: text.slice(0,200), authorId: currentUser.uid,
      authorName: currentUser.displayName || (currentUser.isAnonymous ? "Guest" : "Friend"),
      parentId, timestamp: serverTimestamp()
    });
    await updateDoc(doc(db, "moods", postId), { commentsCount: increment(1) });
    input.value = ""; delete input.dataset.parentId;
  } catch(err){ console.error(err); showToast("Couldn't post comment.", "error"); }
}

function renderComments(postId){
  if(commentUnsubs[postId]) return;
  const commentsCol = collection(db, "moods", postId, "comments");
  const cq = query(commentsCol, orderBy("timestamp","asc"), limit(200));
  commentUnsubs[postId] = onSnapshot(cq, (snap) => {
    commentsCache[postId] = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    paintComments(postId);
  }, (err) => console.error(err));
}

function commentRowHtml(c, postId, indent){
  const isOwn = currentUser && c.authorId === currentUser.uid;
  if(editingComment && editingComment.postId === postId && editingComment.commentId === c.id){
    return `<div class="${indent ? "ml-6" : ""} mt-1.5 flex gap-2 items-center">
      <input class="editCommentInput flex-1 bg-white/10 rounded px-2 py-1 text-xs outline-none" data-commentid="${c.id}" value="${escapeHtml(c.text)}">
      <button class="saveCommentEdit text-xs text-emerald-300" data-postid="${postId}" data-commentid="${c.id}">Save</button>
      <button class="cancelCommentEdit text-xs text-white/40" data-postid="${postId}">Cancel</button>
    </div>`;
  }
  return `<div class="${indent ? "ml-6 mt-1.5" : ""} text-xs">
    <span class="font-medium">${escapeHtml(c.authorName)}</span>
    <span class="text-white/70"> ${escapeHtml(c.text)}</span>${c.edited ? ' <span class="text-white/25">(edited)</span>' : ""}
    ${!indent ? `<button class="replyBtn text-white/30 hover:text-white/60 ml-2" data-postid="${postId}" data-commentid="${c.id}" data-handle="${escapeHtml(c.authorName)}">Reply</button>` : ""}
    ${isOwn ? `<button class="editCommentBtn text-white/30 hover:text-white/60 ml-2" data-postid="${postId}" data-commentid="${c.id}">✏️ Edit</button>
    <button class="deleteCommentBtn text-white/30 hover:text-red-300 ml-2" data-postid="${postId}" data-commentid="${c.id}">🗑️ Delete</button>` : ""}
  </div>`;
}

function paintComments(postId){
  const wrap = els.feedList.querySelector(`.commentsWrap[data-id="${postId}"]`);
  if(!wrap) return;
  const listEl = wrap.querySelector(".commentsList");
  const all = commentsCache[postId] || [];
  const top = all.filter(c => !c.parentId);
  if(top.length === 0){ setHtmlIfChanged(listEl, `<div class="text-xs text-white/30">No comments yet — be the first to reply.</div>`); return; }
  const html = top.map(c => {
    const replies = all.filter(r => r.parentId === c.id);
    const repliesHtml = replies.map(r => commentRowHtml(r, postId, true)).join("");
    return commentRowHtml(c, postId, false) + repliesHtml;
  }).join("");
  setHtmlIfChanged(listEl, html);
}

