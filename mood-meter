/* ---------------- Calendar ---------------- */
function renderCalendar(){
  const year = calViewDate.getFullYear();
  const month = calViewDate.getMonth();
  els.calLabel.textContent = calViewDate.toLocaleDateString(undefined, { month: "long", year: "numeric" });
  const dayMap = {};
  myDocs.forEach(d => { if(d.day && !dayMap[d.day]) dayMap[d.day] = d; });
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month+1, 0).getDate();
  const todayKey = todayStr();
  const cellsHtml = [];
  for(let i=0;i<firstDay;i++){ cellsHtml.push(`<div></div>`); }
  for(let day=1; day<=daysInMonth; day++){
    // Timezone-safe local key — matches exactly how `day` is stored on write.
    const key = localDateStr(new Date(year, month, day));
    const entry = dayMap[key];
    let style = "background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.25);";
    if(entry){
      const m = getMoodMeta(entry);
      style = `background:rgba(${m.glow},0.85); color:#0B0C14; font-weight:600;`;
    }
    if(key === todayKey) style += " box-shadow:0 0 0 2px rgba(255,255,255,0.5) inset;";
    cellsHtml.push(`<div class="cal-day" data-key="${key}" style="${style}">${day}</div>`);
  }
  setHtmlIfChanged(els.calendarGrid, cellsHtml.join(""));
}
els.calendarGrid.addEventListener("click", (e) => {
  const cell = e.target.closest(".cal-day[data-key]");
  if(!cell) return;
  const entry = myDocs.find(d => d.day === cell.dataset.key);
  if(entry) openEntryModal(entry);
});
els.calPrev.addEventListener("click", () => { calViewDate.setMonth(calViewDate.getMonth()-1); renderCalendar(); });
els.calNext.addEventListener("click", () => { calViewDate.setMonth(calViewDate.getMonth()+1); renderCalendar(); });

