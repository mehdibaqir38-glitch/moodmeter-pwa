/* ---------------- Functional social sharing ---------------- */
function getDailyGlobalShareText(){
  const total = globalDayDocs.length;
  const counts = buildMoodCounts();
  globalDayDocs.forEach(d => { if(counts[d.mood] !== undefined) counts[d.mood]++; });
  const denom = total || 1;
  const lines = Object.entries(MOODS).map(([k,m]) => `${m.emoji} ${m.label}: ${Math.round((counts[k]/denom)*100)}%`).join(", ");
  const pageUrl = window.location.href;
  if(globalMode === "daily"){
    const dateObj = new Date(globalSelectedDate + "T00:00:00");
    const label = dateObj.toLocaleDateString(undefined, { month: "long", day: "numeric", year: "numeric" });
    return `The community's Global Vibe on MoodMeter 🌗 for ${label}: ${lines}. Total check-ins that day: ${total}. Trace your footprint live here: ${pageUrl}`;
  }
  const [y, m] = globalSelectedMonth.split("-").map(Number);
  const label = `${MONTH_NAMES[m-1]} ${y}`;
  return `The community's Global Vibe on MoodMeter 🌗 for ${label}: ${lines}. Total check-ins that month: ${total}. Trace your footprint live here: ${pageUrl}`;
}
function getMyMonthlyShareText(){
  const monthKey = `${myMonthYearSelVal}-${String(myMonthSelVal+1).padStart(2,"0")}`;
  const monthDocs = myDocs.filter(d => d.day && d.day.slice(0,7) === monthKey);
  const total = monthDocs.length || 1;
  const counts = buildMoodCounts();
  monthDocs.forEach(d => { if(counts[d.mood] !== undefined) counts[d.mood]++; });
  const topEntry = Object.entries(counts).sort((a,b) => b[1]-a[1])[0];
  const topPct = Math.round((topEntry[1]/total)*100);
  const topLabel = MOODS[topEntry[0]].label;
  const pageUrl = window.location.href;
  return `My ${MONTH_NAMES[myMonthSelVal]} ${myMonthYearSelVal} analytics report on MoodMeter is showing ${topPct}% ${topLabel} vibes! 🌗 Trace your footprint live here: ${pageUrl}`;
}
function getMyYearlyShareText(){
  const yearDocs = myDocs.filter(d => d.day && d.day.slice(0,4) === String(myYearSelVal));
  const total = yearDocs.length || 1;
  const counts = buildMoodCounts();
  yearDocs.forEach(d => { if(counts[d.mood] !== undefined) counts[d.mood]++; });
  const topEntry = Object.entries(counts).sort((a,b) => b[1]-a[1])[0];
