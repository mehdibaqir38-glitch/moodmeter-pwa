const MONTH_NAMES = ["January","February","March","April","May","June","July","August","September","October","November","December"];

function buildMoodCounts(){ return { happy:0, sad:0, angry:0, calm:0, stressed:0, neutral:0 }; }

function renderDonutSVG(container, counts, total){
  const size = 180, cx = size/2, cy = size/2, r = 70, stroke = 26;
  const circumference = 2 * Math.PI * r;
  let offset = 0;
  const segs = Object.entries(MOODS).map(([key,m]) => {
    const val = counts[key] || 0;
    const pct = total > 0 ? val/total : 0;
    const dash = pct * circumference;
    const seg = `<circle class="segpath" cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${m.bar}" stroke-width="${stroke}"
      stroke-dasharray="${dash} ${circumference-dash}" stroke-dashoffset="${-offset}" stroke-linecap="butt" transform="rotate(-90 ${cx} ${cy})"></circle>`;
    offset += dash;
    return seg;
  }).join("");
  const html = `
    <svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="${stroke}"></circle>
      ${segs}
    </svg>
    <div class="donut-center">
      <div class="display text-2xl font-bold">${total}</div>
      <div class="text-[10px] text-white/40">entries</div>
    </div>`;
  setHtmlIfChanged(container, html);
  container.style.position = "relative";
  container.style.width = size+"px";
  container.style.height = size+"px";
}

function paintMoodBreakdownBars(container, counts, total, emptyMsg){
  if(total === 0){
    setHtmlIfChanged(container, `<div class="text-sm text-white/30 text-center py-6">${emptyMsg}</div>`);
    return;
  }
  const html = Object.entries(MOODS).map(([key,m]) => {
    const val = counts[key] || 0;
    const pct = Math.round((val/total)*100);
    return `<div>
      <div class="flex justify-between text-xs mb-1"><span>${m.emoji} ${m.label}</span><span class="text-white/40">${val} logs · ${pct}%</span></div>
      <div class="w-full h-2.5 rounded-full bg-white/10 overflow-hidden"><div class="bar-fill h-full rounded-full" style="width:${pct}%; background:${m.bar};"></div></div>
    </div>`;
  }).join("");
  setHtmlIfChanged(container, html);
}

function paintPersonalBreakdown(container, docsArr){
  const total = docsArr.length;
  const counts = buildMoodCounts();
  docsArr.forEach(d => { if(counts[d.mood] !== undefined) counts[d.mood]++; });
  if(total === 0){
    setHtmlIfChanged(container, `<div class="text-sm text-white/30 text-center py-4">No entries logged in this period yet.</div>`);
    return;
  }
  const html = Object.entries(MOODS).map(([key,m]) => {
    const pct = Math.round((counts[key]/total)*100);
    return `<div class="personal-mood-row glass rounded-xl p-3 flex items-center gap-3" style="border-color: rgba(${m.glow},0.35); background: linear-gradient(90deg, rgba(${m.glow},0.10), transparent);">
      <span class="text-xl flex-shrink-0">${m.emoji}</span>
      <div class="flex-1 min-w-0">
        <div class="flex justify-between text-xs mb-1"><span class="font-medium">${m.label}</span><span class="text-white/50">${pct}% · ${counts[key]} logs</span></div>
        <div class="w-full h-2 rounded-full bg-white/10 overflow-hidden"><div class="bar-fill h-full rounded-full" style="width:${pct}%; background:${m.bar};"></div></div>
      </div>
    </div>`;
  }).join("");
  setHtmlIfChanged(container, html);
}

