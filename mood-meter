async function handleFeedClick(e){
  const profileLink = e.target.closest(".profileLink");
  if(profileLink){ openProfileModal(profileLink.dataset.uid, profileLink.dataset.name); return; }
  const reactBtn = e.target.closest(".reactBtn");
  if(reactBtn){
    if(!currentUser) return;
    reactBtn.style.pointerEvents = "none";
    const targetDoc = findDocById(reactBtn.dataset.id);
    const already = targetDoc && userReacted(targetDoc, reactBtn.dataset.r);
    try{
      const field = `reactionsMeta.${reactBtn.dataset.r}.${currentUser.uid}`;
      await updateDoc(doc(db, "moods", reactBtn.dataset.id), { [field]: already ? deleteField() : true });
    } catch(err){ console.error(err); showToast("Couldn't send reaction.", "error"); }
    reactBtn.style.pointerEvents = "";
    return;
  }
  const followBtn = e.target.closest(".followBtn");
  if(followBtn){ toggleFollow(followBtn.dataset.id); return; }
  const msgReqBtn = e.target.closest(".msgReqBtn");
  if(msgReqBtn){ openChatFullPage(msgReqBtn.dataset.id, msgReqBtn.dataset.name); return; }
  const toggleBtn = e.target.closest(".toggleComments");
  if(toggleBtn){
    const id = toggleBtn.dataset.id;
    const wrap = els.feedList.querySelector(`.commentsWrap[data-id="${id}"]`);
    if(!wrap) return;
    if(openCommentsFor.has(id)){
      openCommentsFor.delete(id);
      wrap.classList.add("hidden");
      const d = findDocById(id);
      toggleBtn.textContent = `💬 View / add comments (${d?.commentsCount || 0})`;
      if(commentUnsubs[id]){ commentUnsubs[id](); delete commentUnsubs[id]; }
    } else {
      openCommentsFor.add(id);
      wrap.classList.remove("hidden");
      const d = findDocById(id);
      toggleBtn.textContent = `💬 Hide comments (${d?.commentsCount || 0})`;
      renderComments(id);
    }
    return;
  }
  const replyBtn = e.target.closest(".replyBtn");
  if(replyBtn){
    const form = els.feedList.querySelector(`.commentForm[data-id="${replyBtn.dataset.postid}"]`);
    const input = form.querySelector(".commentInput");
    input.value = `@${replyBtn.dataset.handle} `;
    input.dataset.parentId = replyBtn.dataset.commentid;
    input.focus();
    return;
  }
  const editBtn = e.target.closest(".editCommentBtn");
  if(editBtn){
    editingComment = { postId: editBtn.dataset.postid, commentId: editBtn.dataset.commentid };
    paintComments(editBtn.dataset.postid);
    return;
  }
  const cancelEditBtn = e.target.closest(".cancelCommentEdit");
  if(cancelEditBtn){
    const postId = cancelEditBtn.dataset.postid;
    editingComment = null;
    paintComments(postId);
    return;
  }
  const saveEditBtn = e.target.closest(".saveCommentEdit");
  if(saveEditBtn){
    const postId = saveEditBtn.dataset.postid;
    const commentId = saveEditBtn.dataset.commentid;
    const input = els.feedList.querySelector(`.editCommentInput[data-commentid="${commentId}"]`);
    const newText = input.value.trim();
    if(!newText) return;
    try{
      await updateDoc(doc(db, "moods", postId, "comments", commentId), { text: newText.slice(0,200), edited: true });
      editingComment = null;
      showToast("Comment updated ✅", "success");
    } catch(err){ console.error(err); showToast("Couldn't update comment.", "error"); }
    return;
  }
  const deleteBtn = e.target.closest(".deleteCommentBtn");
  if(deleteBtn){
    if(!confirm("Delete this comment?")) return;
    try{
      await deleteDoc(doc(db, "moods", deleteBtn.dataset.postid, "comments", deleteBtn.dataset.commentid));
      await updateDoc(doc(db, "moods", deleteBtn.dataset.postid), { commentsCount: increment(-1) });
      showToast("Comment deleted 🗑️", "success");
    } catch(err){ console.error(err); showToast("Couldn't delete comment.", "error"); }
    return;
  }
}

