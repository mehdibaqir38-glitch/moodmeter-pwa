            ${nameHtml(d)}<span class="text-xs text-white/30">${isMine ? "(you) · " : ""}${timeAgo(d.timestamp)}</span>
          </div>
          <div class="text-xs text-white/40 mb-1">feeling ${m.label.toLowerCase()} ${d.isPublic === false ? "· 🔒 private" : ""}</div>
          ${d.note ? `<p class="text-sm text-white/80 break-words mb-2">${escapeHtml(d.note)}</p>` : ""}
