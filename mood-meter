function openChatFullPage(targetId, targetName){
  if(!currentUser || !targetId || targetId === currentUser.uid) return;

  // ---- 1) ALWAYS tear down any previous conversation's listener first ----
  // This guarantees there is never more than one active Firestore listener
  // for a conversation, even if the user is rapidly tapping between chats
  // or reopening the exact same conversation they just left.
  if(typeof currentChatUnsubscribe === "function"){
    currentChatUnsubscribe();
    currentChatUnsubscribe = null;
  }

  currentConvTarget = targetId;
  currentConvId = [currentUser.uid, targetId].sort().join("_");
  chatHeaderTargetName = targetName || nameFor(targetId) || "Friend";
  els.chatHeaderName.textContent = chatHeaderTargetName;
  els.chatHeaderAvatar.textContent = chatHeaderTargetName.charAt(0).toUpperCase();

  // ---- 2) Reset stale DOM/cache state before showing the loading state ----
  // ROOT CAUSE OF THE "stuck on Loading conversation…" BUG:
  // paintMessages() writes chatBody's HTML through setHtmlIfChanged(), which
  // skips the actual DOM write whenever the computed HTML is byte-identical
  // to what it last cached for that element (a perf optimization). Setting
  // chatBody.innerHTML directly here (for the loading placeholder) does NOT
  // go through that helper, so it never updates the cache — it only
  // overwrites the visible DOM. The result: if you reopen the exact same
  // conversation, the new snapshot's first payload can be identical to what
  // was cached from the previous time this chat was open, so
  // setHtmlIfChanged() thinks "nothing changed" and silently skips the
  // write — leaving the manually-inserted "Loading conversation…" text on
  // screen forever. Explicitly invalidating the cache entry for chatBody
  // here (and again on close) guarantees the next real paint always lands.
  _lastHtmlCache.delete(els.chatBody);
  els.chatBody.innerHTML = `<div class="text-xs text-white/30 text-center py-8">Loading conversation…</div>`;

  els.chatFullPage.classList.remove("hidden");
  els.chatFullPage.style.display = "flex";
  document.body.style.overflow = "hidden";
  updateChatHeaderPresence();
  updateChatHeaderBlockBtn();
  updateChatBanner();
  markConversationRead(currentConvId, currentUser.uid);
  updateMessageBadges();

  // ---- 3) Create a brand-new query + listener for this open, every time ----
  const openedForConvId = currentConvId; // snapshot the id this listener belongs to
  const msgsCol = collection(db, "conversations", currentConvId, "messages");
  const q = query(msgsCol, orderBy("timestamp","asc"), limit(300));
  currentChatUnsubscribe = onSnapshot(q, (snap) => {
    // Guard against a late callback from a listener that should already
    // have been torn down (e.g. user switched conversations before this
    // fired) — never paint stale data into the currently-open thread.
    if(openedForConvId !== currentConvId) return;
    const msgs = snap.docs.map(d => ({ id: d.id, ...d.data() }));
    paintMessages(msgs);
    markMessagesRead(currentConvId, currentUser.uid, msgs);
  }, (err) => {
    console.error("[MoodMeter] Chat listener failed for conversation", openedForConvId, err);
    if(openedForConvId !== currentConvId) return;
    _lastHtmlCache.delete(els.chatBody);
    els.chatBody.innerHTML = `<div class="text-xs text-red-300 text-center py-8">Couldn't load messages — check Firestore rules.</div>`;
  });
}
function closeChatFullPage(){
  els.chatFullPage.classList.add("hidden");
  els.chatFullPage.style.display = "none";
  document.body.style.overflow = "";

  // Full teardown of everything tied to the conversation that was open —
  // listener, ids, and any cached DOM snapshot for the chat body — so the
  // next openChatFullPage() call (even for the same conversation) starts
  // from a completely clean slate.
  if(typeof currentChatUnsubscribe === "function"){
    currentChatUnsubscribe();
    currentChatUnsubscribe = null;
  }
  currentConvId = null;
  currentConvTarget = null;
  _lastHtmlCache.delete(els.chatBody);
  els.chatBody.innerHTML = "";
}
els.chatBackBtn.addEventListener("click", closeChatFullPage);

els.chatBlockToggleBtn.addEventListener("click", () => {
