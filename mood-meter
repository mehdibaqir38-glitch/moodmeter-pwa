function docsForUser(uid){
  const map = new Map();
  [...communityDocs, ...feedDocs, ...trendingDocs, ...myDocs].forEach(d => { if(d.userId === uid) map.set(d.id, d); });
  return [...map.values()];
}
function streakFromDocs(docsArr){
  const daySet = new Set(docsArr.map(d => d.day).filter(Boolean));
  let streak = 0; let d = new Date();
  while(true){
    const key = localDateStr(d);
    if(daySet.has(key)){ streak++; d.setDate(d.getDate()-1); } else break;
  }
  return streak;
}
